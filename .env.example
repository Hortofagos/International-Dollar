# Comma-separated base85 issuer public keys accepted for genesis tokens.
IND_TRUSTED_GENESIS_ISSUER_KEYS=

# Optional comma-separated signed supply manifest hashes. This lets public nodes
# pin the exact launch supply map instead of trusting any future issuer-signed map.
IND_TRUSTED_GENESIS_MANIFEST_HASHES=

# Local tests only. Public nodes should leave this off and pin issuer keys above.
IND_ALLOW_UNTRUSTED_GENESIS=0

# Public nodes may raise this. The implementation clamps the minimum to 60.
IND_FINALITY_BUFFER_SECONDS=60

# Wire safety limits. Raising these permits heavier legacy bills but increases DoS risk.
IND_MAX_WIRE_COMPRESSED_BYTES=16777216
IND_MAX_WIRE_DECOMPRESSED_BYTES=67108864

# Verification-key cache size for repeated ECDSA checks.
IND_MAX_VERIFY_KEY_CACHE=4096

# Transparency operator HTTP request limits.
IND_LOG_MAX_APPEND_BODY_BYTES=16777216
IND_LOG_APPEND_BODY_READ_TIMEOUT_SECONDS=10

# Auto-update safety. Unsigned commits are rejected unless this local escape hatch
# is set. Dependency installation is also opt-in because it executes package code.
IND_UPDATE_ALLOW_UNSIGNED=0
IND_UPDATE_INSTALL_DEPS=0
