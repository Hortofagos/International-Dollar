# Comma-separated base85 issuer public keys accepted for genesis bills.
IND_TRUSTED_GENESIS_ISSUER_KEYS=

# Optional comma-separated signed supply manifest hashes. This lets public nodes
# pin the exact launch supply map instead of trusting any future issuer-signed map.
IND_TRUSTED_GENESIS_MANIFEST_HASHES=

# Local tests only. Public nodes should leave this off and pin issuer keys above.
IND_ALLOW_UNTRUSTED_GENESIS=0

# Network selector. Leave as mainnet for the ordinary network, or set testnet
# to use the public testnet port, peer cache, runtime folders, and local store.
IND_NETWORK=mainnet

# Optional override. Defaults are 8888 on mainnet and 18888 on testnet.
IND_NODE_PORT=

# Optional local SQLite override. Defaults are ind_gossip.db on mainnet and
# ind_gossip_testnet.db on testnet.
IND_STORE_PATH=

# Comma-separated DNS seed hosts. Publish node A and AAAA records under these
# names; the resolver filters private/non-routable IPv4/IPv6 results and caches
# the rest as peers.
# Testnet defaults are testnet-seed.international-dollar.com and
# testnet-seed.internetofthebots.com.
IND_DNS_SEED_HOSTS=seed.international-dollar.com,seed.linkifier.me,seed.internetofthebots.com

# Comma-separated explicit bootstrap peers. Useful before DNS seeds are live.
# IPv6 literals may be written raw or bracketed, for example [2606:...]:8888.
IND_PEER_PING_SERVERS=

# Default is 60 seconds. Lower values settle faster but leave less time for
# double-spend conflict gossip to arrive before local acceptance.
IND_FINALITY_BUFFER_SECONDS=60

# Compact bill checkpoint policy. Automatic checkpoints start once a bill has
# this many settled transfers, then repeat after this many additional settled
# transfers. Set IND_HIGH_VALUE_CHECKPOINT_THRESHOLD to a positive bill value to
# checkpoint those bills immediately after each settled payment; 0 disables the
# high-value shortcut.
IND_FIRST_CHECKPOINT_AFTER_TRANSFERS=10
IND_CHECKPOINT_INTERVAL_TRANSFERS=10
IND_HIGH_VALUE_CHECKPOINT_THRESHOLD=0

# Wire safety limits. Raising these permits heavier legacy bills but increases DoS risk.
IND_MAX_WIRE_COMPRESSED_BYTES=2097152
IND_MAX_WIRE_DECOMPRESSED_BYTES=8388608
IND_REJECT_PEER_KEY_CHANGES=0

# Gossip node capacity. "auto" uses the operator profile when this machine is
# configured as a transparency operator; peers do not get special remote trust.
IND_NODE_CAPACITY_PROFILE=auto
IND_NODE_RATE_WINDOW_SECONDS=60
IND_NODE_GOSSIP_RATE_PER_IP=50
IND_NODE_GOSSIP_BURST_PER_IP=1000
IND_NODE_GOSSIP_RATE_PER_SUBNET=200
IND_NODE_GOSSIP_BURST_PER_SUBNET=4000
IND_NODE_GOSSIP_RATE_GLOBAL=500
IND_NODE_GOSSIP_BURST_GLOBAL=5000
IND_NODE_EVIDENCE_RATE_PER_IP=5
IND_NODE_EVIDENCE_BURST_PER_IP=50
IND_NODE_EVIDENCE_RATE_PER_SUBNET=20
IND_NODE_EVIDENCE_BURST_PER_SUBNET=200
IND_NODE_EVIDENCE_RATE_GLOBAL=50
IND_NODE_EVIDENCE_BURST_GLOBAL=500
IND_NODE_CRITICAL_RATE_PER_IP=10
IND_NODE_CRITICAL_BURST_PER_IP=200
IND_NODE_CRITICAL_RATE_GLOBAL=100
IND_NODE_CRITICAL_BURST_GLOBAL=1000
IND_NODE_CONTROL_RATE_PER_IP=50
IND_NODE_CONTROL_BURST_PER_IP=500
IND_NODE_CONTROL_RATE_GLOBAL=500
IND_NODE_CONTROL_BURST_GLOBAL=5000
IND_NODE_INVALID_RATE_PER_IP=10
IND_NODE_INVALID_BURST_PER_IP=100
IND_NODE_GOSSIP_QUEUE_MAX=10000
IND_NODE_CRITICAL_QUEUE_MAX=1000
IND_NODE_GOSSIP_WORKERS=16
IND_NODE_GOSSIP_BATCH_MAX_MESSAGES=64
IND_NODE_GOSSIP_BATCH_MAX_BYTES=1048576
IND_NODE_REBROADCAST_INTERVAL_SECONDS=2
IND_NODE_REBROADCAST_BATCH_MAX_MESSAGES=32
IND_NODE_REBROADCAST_FANOUT=3
IND_NODE_CRITICAL_REBROADCAST_FANOUT=8
IND_NODE_MAX_GOSSIP_POOL_MESSAGES=5000
IND_NODE_MAX_CONNECTIONS_PER_IP_WINDOW=480
IND_NODE_MAX_ACTIVE_CONNECTIONS=128
IND_NODE_MAX_ACTIVE_CONNECTIONS_PER_IP=24
IND_NODE_REQUEST_TIMEOUT_SECONDS=10
IND_NODE_SOCKET_BACKLOG=128
IND_NODE_MAX_STATUS_REFS_PER_REQUEST=200

# Backoff for stale pending V3 transfer-log proof recovery. Old test records
# that keep returning HTTP 400 are retried politely and then silenced.
IND_V3_LOG_PROOF_RETRY_INITIAL_SECONDS=60
IND_V3_LOG_PROOF_RETRY_MAX_SECONDS=3600
IND_V3_LOG_PROOF_STALE_HTTP_400_ATTEMPTS=3

# Wallet-side outgoing gossip pacing. This keeps bulk sends smooth and below
# the ordinary peer gossip cap instead of making peers reject bursts.
IND_WALLET_SEND_WINDOW_SECONDS=5
IND_WALLET_MAX_GOSSIP_PER_PEER_WINDOW=10

# Verification-key cache size for repeated operator signature checks.
IND_MAX_VERIFY_KEY_CACHE=4096

# Transparency operator HTTP request limits.
#
# The transparency operator stores its append log in SQLite by default. Serious
# append-capable operators may opt into MariaDB for canonical operator truth.
# Redis/NoSQL must not be used as canonical ledger/operator truth.
IND_REQUIRE_TRANSPARENCY_LOG=1
IND_SUBMIT_TO_TRANSPARENCY_LOG=1
IND_LOG_OPERATOR_URL=
IND_LOG_MIRROR_URLS=
IND_LOG_OPERATOR_PUBLIC_KEY=
# Max append-capable operators a wallet/node submits to for one transfer.
# The core domains are always pinned into this selected pool when configured.
IND_OPERATOR_APPEND_FANOUT=5
IND_OPERATOR_CORE_DOMAINS=international-dollar.com,internetofthebots.com
# 0 means require a majority of selected append-capable transparency operators.
IND_OPERATOR_FINALITY_MIN_PROOFS=0
# Dev/test only: accept checkpoint roots embedded in compact bills without a
# trusted mirror verifier or pinned operator key. Never enable in production.
IND_ALLOW_UNTRUSTED_EMBEDDED_ROOTS=0
IND_LOG_DB=files/ind_transparency_log.db
# sqlite is the default for local/dev. mariadb is only for append-capable
# operator services with backups/monitoring in place.
IND_LOG_BACKEND=sqlite
# MariaDB must be local-only: 127.0.0.1/localhost/::1 or a Unix socket.
# Use SSH tunnels for remote administration; never expose 3306 publicly.
IND_LOG_MARIADB_HOST=127.0.0.1
IND_LOG_MARIADB_PORT=3306
IND_LOG_MARIADB_UNIX_SOCKET=
IND_LOG_MARIADB_DATABASE=
IND_LOG_MARIADB_USER=
IND_LOG_MARIADB_PASSWORD_FILE=
IND_LOG_MARIADB_TLS=0
IND_LOG_MARIADB_SSL_CA=
# Set to 1 for small local mirrors that should serve full proof archives.
# Keep 0 for public/high-volume mirrors; use segmented hash-log exports instead.
IND_LOG_WRITE_MIRROR_PROOF_ARCHIVES=0
IND_LOG_MAX_APPEND_BODY_BYTES=8388608
IND_LOG_APPEND_BODY_READ_TIMEOUT_SECONDS=10

# Testnet/operator monitoring: comma-separated public root mirror base URLs or
# latest.json URLs that must stay fresh enough for strict current verification.
IND_TESTNET_MONITOR_MIRROR_ROOT_URLS=

# Auto-update safety. Public automatic checks stay off until /update publishes
# signed manifests. Unsigned commits are rejected unless this local escape hatch
# is set. Dependency installation is also opt-in because it executes package code.
IND_AUTO_UPDATE=0
IND_UPDATE_SOURCE=international-dollar.com/update
IND_UPDATE_ALLOW_UNSIGNED=0
IND_UPDATE_INSTALL_DEPS=0
